# Supabase（サーバー専用。VITE_ にしない）
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_EVENTS_TABLE=zyakudan_events

# 管理画面「プレイ履歴」API（本番必須）
ZYAKUDAN_ADMIN_PASSWORD=your-long-password

# フロントに埋め込まれる（Vercel Production）
VITE_SITE_URL=https://your-app.vercel.app
VITE_ENABLE_ADMIN=true

# 開発サーバー保存API（任意）
SAVE_CONTENT_TOKEN=your-secret
VITE_SAVE_CONTENT_TOKEN=your-secret
