# ローカル専用（.env.local にコピー。Git に上げない）
# 本番のプレイ履歴をローカル管理画面で見るために必要
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_EVENTS_TABLE=zyakudan_events

# ローカルで save-content API を保護したいときだけ（任意）
SAVE_CONTENT_TOKEN=your-secret
VITE_SAVE_CONTENT_TOKEN=your-secret

# 本番ビルド用（Vercel Production に設定。VITE_ はフロントに埋め込まれる）
# VITE_SITE_URL=https://zyakudan-sukue.vercel.app
